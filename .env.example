TICKET_CATEGORY_ID=category_id_here
TICKET_PANEL_CHANNEL_ID=panel_channel_id_here
# Comma-separated staff role IDs (Support, Ticket Team, etc.)
STAFF_ROLE_IDS=role_id_1,role_id_2
# Optional: channel to log closed tickets
TICKET_LOGS_CHANNEL_ID=
